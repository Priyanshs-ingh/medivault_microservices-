# ========================================
# PRODUCTION RAG Bot - Environment Configuration
# 100% Cost-Free Stack
# ========================================

# ========== LLM Configuration (PRODUCTION: Ollama) ==========
# Local deployment for zero API costs
LLM_PROVIDER=ollama
LLM_MODEL=llama3
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1500

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434

# Alternative Cloud Providers (not recommended for production if cost-free)
# GROQ_API_KEY=your_groq_key_here
# TOGETHER_API_KEY=your_together_key_here
# OPENAI_API_KEY=your_openai_key_here

# ========== Embedding Configuration (PRODUCTION) ==========
# Use local embeddings for cost-free deployment
USE_LOCAL_EMBEDDINGS=true

# Production Model: BGE-base-en-v1.5 (SOTA for retrieval)
LOCAL_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768

# OpenAI embeddings (only if USE_LOCAL_EMBEDDINGS=false)
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=your_openai_key_here

# ========== MongoDB Configuration (PRODUCTION) ==========
# For MongoDB Atlas (cloud - has free tier)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# Database and Collection Names (customize as needed)
MONGODB_DB_NAME=medical_ragbot
MONGODB_COLLECTION_NAME=medical_vectors

# Document Versioning (production requirement)
ENABLE_DOCUMENT_VERSIONING=true
DOCUMENT_VERSION=v1.0

# ========== Chunking Configuration (PRODUCTION-OPTIMIZED) ==========
CHUNK_SIZE=600
CHUNK_OVERLAP_PERCENT=0.25
USE_SENTENCE_BOUNDARIES=true

# ========== Data Directories ==========
DATA_DIR=data
RAW_PDFS_DIR=data/raw_pdfs
PROCESSED_TEXT_DIR=data/processed_text

# ========== OCR Configuration ==========
# Required for scanned/handwritten PDFs

# Windows: Install from https://github.com/UB-Mannheim/tesseract/wiki
# Example: TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Windows: Install from https://github.com/oschwartz10612/poppler-windows/releases
# Example: POPPLER_PATH=C:\poppler\poppler-24.08.0\Library\bin
POPPLER_PATH=C:\poppler\poppler-24.08.0\Library\bin

OCR_LANGUAGE=eng

# ========== API Configuration ==========
API_HOST=0.0.0.0
API_PORT=8000

# ========== Vector Search Configuration (PRODUCTION) ==========
# IMPORTANT: Vector index name must match what you create in MongoDB Atlas
VECTOR_INDEX_NAME=vector_index
VECTOR_SEARCH_CANDIDATES_MULTIPLIER=10
RETRIEVAL_MAX_TOKENS=3000

# ========== RAG Configuration ==========
DEFAULT_RETRIEVAL_K=5
MULTI_STAGE_INITIAL_K=20
MAX_CONTEXT_LENGTH=3500


